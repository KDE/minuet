<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/minuet_splash_background"/>
    <item android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/minuet_splash_icon"/>
    </item>
    <item android:bottom="24dp" android:gravity="bottom|center_horizontal">
        <bitmap
            android:gravity="bottom|center_horizontal"
            android:src="@drawable/minuet_splash_branding"/>
    </item>
</layer-list>
